{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "node",
    "strict": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["client/*"],
      "@components/*": ["client/components/*"],
      "@components/ui/*": ["client/components/ui/*"],
      "@styles/*": ["client/styles/*"],
      "@utils/*": ["client/utils/*"],
      "@shared/*": ["shared/*"]
    },
    "types": ["node", "react", "react-dom", "vite/client"],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "client/**/*",
    "server/**/*",
    "shared/**/*",
    "*.ts",
    "*.tsx"
  ],
  "exclude": ["node_modules", "coverage", "tests", "dist"]
}
